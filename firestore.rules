rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin-only collections (write) ─────────────────────────────────────
    // Only authenticated users (admins) can write; public can read display data.

    match /advertisements/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /content/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /tickers/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /screens/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /broadcast/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /screen_groups/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /youtube_videos/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /video_playlists/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /instagram_posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Screen commands (Firestore real-time sync) ─────────────────────────
    // Screens listen here; only authenticated users can write commands.
    match /screen_commands/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Analytics (append-only from display screens) ───────────────────────
    match /analytics/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
  }
}
