# ========================================
# SOCIAL TV - Environment Variables
# ========================================
# Copy this file to .env.local and fill in the values.

# Firebase Web App
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID="social-web-tv"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Admin API hardening
# Legacy broad allow list. If set, matching users are treated as `ops`.
ADMIN_ALLOWED_EMAILS=""
# Role-based access lists
ADMIN_OPS_EMAILS="ops@example.com"
ADMIN_EDITOR_EMAILS="editor@example.com"
ADMIN_VIEWER_EMAILS="viewer@example.com"
# In production set to true.
ADMIN_API_STRICT="true"

# OpenAI API Key
OPENAI_API_KEY="sk-..."

# Optional runtime metadata
NODE_ENV="production"

# Weather defaults
WEATHER_LAT="41.0082"
WEATHER_LON="28.9784"
WEATHER_CITY="Istanbul"

# Display polling defaults
NEXT_PUBLIC_REFRESH_INTERVAL="30000"

# Provider/API secrets can be added here if external licensed feeds require them.
# Example:
# TABII_EMBED_BASE_URL="https://..."
# BEIN_EMBED_BASE_URL="https://..."
